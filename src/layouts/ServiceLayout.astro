---
import Layout from './Layout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description: string;
  serviceName: string;
  locale?: string;
}

const { title, description, serviceName, locale = 'de' } = Astro.props;
const isGerman = locale === 'de';
---

<Layout title={title} description={description} lang={locale}>
  <Navigation currentLocale={locale} currentPath={isGerman ? `/services/${serviceName.toLowerCase().replace(/\s+/g, '-')}` : `/en/services/${serviceName.toLowerCase().replace(/\s+/g, '-')}`} />
  <main class="pt-16">
    <slot />
  </main>
  <Footer locale={locale} />
</Layout>
