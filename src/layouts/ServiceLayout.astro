---
import Layout from './Layout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';

import type { Locale } from '../i18n/translations';

interface Props {
  title: string;
  description: string;
  serviceName: string;
  locale?: Locale;
}

const { title, description, serviceName, locale = 'de' } = Astro.props;
const isGerman = locale === 'de';

// Get the actual current URL path
const currentPath = Astro.url.pathname;
---

<Layout title={title} description={description} lang={locale}>
  <Navigation currentLocale={locale} currentPath={currentPath} isServicePage={true} />
  <main class="pt-16">
    <slot />
  </main>
  <Footer locale={locale} isServicePage={true} />
</Layout>
