---
import Layout from '../../layouts/Layout.astro';
import Navigation from '../../components/Navigation.astro';
import Hero from '../../components/Hero.astro';
import Services from '../../components/Services.astro';
import Story from '../../components/Story.astro';
import Contact from '../../components/Contact.astro';
import Footer from '../../components/Footer.astro';
import { getTranslations } from '../../i18n/translations';

const locale = 'en';
const t = getTranslations(locale);
---

<Layout 
  title="Jakob Lingel - Digital Solutions Provider" 
  description="From idea to deployment in record time. Custom websites, webshops, cloud infrastructure, and security consulting."
  lang={locale}
>
  <Navigation currentLocale={locale} currentPath="/en/" />
  <main>
    <Hero locale={locale} />
    <Services locale={locale} />
    <Story locale={locale} />
    <Contact locale={locale} />
  </main>
  <Footer locale={locale} />
</Layout>
