---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
import Hero from '../components/Hero.astro';
import Services from '../components/Services.astro';
import Story from '../components/Story.astro';
import Contact from '../components/Contact.astro';
import Footer from '../components/Footer.astro';
import { getTranslations } from '../i18n/translations';

const locale = 'de';
const t = getTranslations(locale);
---

<Layout 
  title="Jakob Lingel - Digital Solutions Provider" 
  description="Von der Idee zum Deployment in Rekordzeit. Maßgeschneiderte Websites, Onlineshops, Cloud-Infrastruktur und Security Consulting."
  lang={locale}
>
  <Navigation currentLocale={locale} currentPath="/" />
  <main>
    <Hero locale={locale} />
    <Services locale={locale} />
    <Story locale={locale} />
    <Contact locale={locale} />
  </main>
  <Footer locale={locale} />
</Layout>


