---
import ServiceLayout from '../../layouts/ServiceLayout.astro';
import ServiceHero from '../../components/service/ServiceHero.astro';
import ProblemSection from '../../components/service/ProblemSection.astro';
import SolutionSection from '../../components/service/SolutionSection.astro';
import BenefitsGrid from '../../components/service/BenefitsGrid.astro';
import ProcessSection from '../../components/service/ProcessSection.astro';
import CTASection from '../../components/service/CTASection.astro';
import RelatedServices from '../../components/service/RelatedServices.astro';
import { getTranslations } from '../../i18n/translations';

const locale = 'de';
const t = getTranslations(locale);

const serviceData = {
  name: t.services.security.title,
  title: t.security.meta.title,
  description: t.security.meta.description,
  tagline: t.security.tagline,
  heroDescription: t.security.heroDescription,
  icon: "lucide:shield",
};

const problemData = {
  headline: "Sind Sie für Angriffe verwundbar?",
  description: "Datenlecks, Ransomware und Compliance-Verstöße können Ihr Unternehmen über Nacht zerstören. Die meisten Unternehmen wissen nicht, wo sie verwundbar sind, bis es zu spät ist.",
  painPoints: [
    "Unbekannte Schwachstellen, die Hacker jederzeit ausnutzen könnten",
    "Kein Incident-Response-Plan, wenn unweigerlich etwas schiefgeht",
    "Compliance-Anforderungen wie DSGVO, bei denen Sie unsicher sind, wie Sie sie erfüllen",
    "Sicherheitspatches, die nie eingespielt werden, weil sie etwas kaputt machen könnten",
  ],
};

const solutionData = {
  headline: "Proaktiver Schutz, der funktioniert",
  description: "Ich verfolge einen ganzheitlichen Sicherheitsansatz—finde Schwachstellen, bevor Angreifer sie finden, implementiere mehrschichtige Abwehr und etabliere Prozesse, die Sie langfristig schützen.",
  features: [
    {
      title: "Umfassende Audits",
      description: "Gründliche Sicherheitsbewertungen von Infrastruktur, Anwendungen und Prozessen. Wissen Sie genau, wo Sie stehen.",
    },
    {
      title: "Schwachstellen-Management",
      description: "Kontinuierliches Scanning, priorisierte Behebung und Patch-Management, das Systeme sicher hält—ohne Funktionalität zu beeinträchtigen.",
    },
    {
      title: "Compliance-Beratung",
      description: "Navigieren Sie DSGVO, BSI und andere Anforderungen mit klaren Roadmaps und Implementierungsunterstützung.",
    },
    {
      title: "Incident Response",
      description: "Vorbereitung, Playbooks und schnelle Response-Fähigkeiten. Wenn etwas passiert, wissen Sie genau, was zu tun ist.",
    },
  ],
};

const benefitsData = {
  headline: "Warum Security-First zählt",
  benefits: [
    {
      icon: "lucide:search",
      title: "Schwachstellen finden",
      description: "Entdecken Sie Sicherheitslücken, bevor Angreifer sie finden—durch umfassende Penetrationstests und Code-Reviews.",
    },
    {
      icon: "lucide:lock",
      title: "Daten schützen",
      description: "Implementieren Sie Verschlüsselung, Zugriffskontrollen und Datenschutz, die Industriestandards erfüllen.",
    },
    {
      icon: "lucide:file-check",
      title: "Compliance erreichen",
      description: "Erfüllen Sie DSGVO, BSI und andere regulatorische Anforderungen mit dokumentierten Sicherheitskontrollen.",
    },
    {
      icon: "lucide:alert-triangle",
      title: "Schnelle Response",
      description: "Incident-Response-Pläne und Support bei Sicherheitsvorfällen. Minimieren Sie Schäden und erholen Sie sich schnell.",
    },
    {
      icon: "lucide:eye",
      title: "Kontinuierliches Monitoring",
      description: "Laufendes Sicherheitsmonitoring mit Alerts bei verdächtigen Aktivitäten und neuen Bedrohungen.",
    },
    {
      icon: "lucide:award",
      title: "Vertrauen aufbauen",
      description: "Nachweisbare Sicherheitsmaßnahmen, die Kundenvertrauen und Wettbewerbsvorteile schaffen.",
    },
  ],
};

const processData = {
  headline: "Vom Assessment zum Schutz",
  description: "Ein systematischer Ansatz, der Ihre Sicherheitslage transparent macht und einen klaren Verbesserungspfad aufzeigt.",
  steps: [
    {
      number: "1",
      title: "Discovery & Bewertung",
      description: "Ich führe ein gründliches Sicherheitsaudit Ihrer Infrastruktur, Anwendungen und Prozesse durch, um Schwachstellen und Compliance-Lücken zu identifizieren.",
    },
    {
      number: "2",
      title: "Risikoanalyse & Priorisierung",
      description: "Wir analysieren die Ergebnisse nach Schweregrad und Geschäftsauswirkung, erstellen eine priorisierte Roadmap und behandeln kritische Issues zuerst.",
    },
    {
      number: "3",
      title: "Implementierung & Härtung",
      description: "Ich implementiere Sicherheitskontrollen, behebe Schwachstellen, richte Monitoring ein und etabliere sichere Entwicklungspraktiken.",
    },
    {
      number: "4",
      title: "Dokumentation & Training",
      description: "Sicherheitsrichtlinien, Incident-Response-Pläne und Team-Training stellen sicher, dass Ihre Sicherheitslage langfristig stark bleibt.",
    },
  ],
};

const ctaData = {
  headline: "Bereit, Ihr Unternehmen abzusichern?",
  description: "Lassen Sie uns Ihre Sicherheitsbedenken besprechen und eine maßgeschneiderte Schutzstrategie für Ihr Unternehmen entwickeln. Von Audits bis laufendem Support—ich helfe Ihnen, ruhiger zu schlafen.",
  buttonText: "Sicherheits-Assessment",
};

const allServices = [
  {
    icon: "lucide:code",
    title: t.services.webDevelopment.title,
    description: t.services.webDevelopment.description,
    href: "/services/web-development",
  },
  {
    icon: "lucide:brain",
    title: t.services.aiEnablement.title,
    description: t.services.aiEnablement.description,
    href: "/services/ai-enablement",
  },
  {
    icon: "lucide:cloud",
    title: t.services.cloudDevops.title,
    description: t.services.cloudDevops.description,
    href: "/services/cloud-devops",
  },
  {
    icon: "lucide:shield",
    title: t.services.security.title,
    description: t.services.security.description,
    href: "/services/security",
  },
];
---

<ServiceLayout
  title={serviceData.title}
  description={serviceData.description}
  serviceName={serviceData.name}
  locale={locale}
>
  <ServiceHero
    title={serviceData.name}
    tagline={serviceData.tagline}
    description={serviceData.heroDescription}
    icon={serviceData.icon}
  />

  <ProblemSection
    headline={problemData.headline}
    description={problemData.description}
    painPoints={problemData.painPoints}
  />

  <SolutionSection
    headline={solutionData.headline}
    description={solutionData.description}
    features={solutionData.features}
  />

  <BenefitsGrid
    headline={benefitsData.headline}
    benefits={benefitsData.benefits}
  />

  <ProcessSection
    headline={processData.headline}
    description={processData.description}
    steps={processData.steps}
  />

  <CTASection
    headline={ctaData.headline}
    description={ctaData.description}
    buttonText={ctaData.buttonText}
  />

  <RelatedServices
    currentService={serviceData.name}
    services={allServices}
  />
</ServiceLayout>
