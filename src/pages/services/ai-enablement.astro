---
import ServiceLayout from '../../layouts/ServiceLayout.astro';
import ServiceHero from '../../components/service/ServiceHero.astro';
import ProblemSection from '../../components/service/ProblemSection.astro';
import SolutionSection from '../../components/service/SolutionSection.astro';
import BenefitsGrid from '../../components/service/BenefitsGrid.astro';
import ProcessSection from '../../components/service/ProcessSection.astro';
import CTASection from '../../components/service/CTASection.astro';
import RelatedServices from '../../components/service/RelatedServices.astro';
import { getTranslations } from '../../i18n/translations';

const locale = 'de';
const t = getTranslations(locale);

const serviceData = {
  name: t.services.aiEnablement.title,
  title: t.aiEnablement.meta.title,
  description: t.aiEnablement.meta.description,
  tagline: t.aiEnablement.tagline,
  heroDescription: t.aiEnablement.heroDescription,
  icon: "lucide:brain",
};

const problemData = {
  headline: "Hängen Sie bei der KI-Transformation hinterher?",
  description: "Unternehmen verlieren täglich an Wettbewerbsfähigkeit, weil sie den Einstieg in Künstliche Intelligenz verpassen. Währenddessen nutzen Wettbewerber KI zur Automatisierung, besseren Entscheidungen und schnellerem Wachstum.",
  painPoints: [
    "Wettbewerber automatisieren bereits Kundenservice, Content-Erstellung und Entscheidungsprozesse mit KI",
    "Ihr Team ist mit repetitiven Aufgaben überlastet, die KI in Sekunden erledigen könnte",
    "Tausende KI-Tools existieren, aber Sie wissen nicht, welche für Ihr Unternehmen wirklich relevant sind",
    "Ohne interne KI-Expertise fühlt sich jede Entscheidung wie ein Risiko an",
  ],
};

const solutionData = {
  headline: "Praxiserprobte KI-Lösungen für Ihr Unternehmen",
  description: "Ich filtere das KI-Hype-Rauschen heraus und identifiziere konkrete, ROI-orientierte Potenziale für Ihr spezifisches Geschäftsmodell. Von Strategie über Implementierung bis Training—ich übernehme die Komplexität, damit Sie die Ergebnisse erzielen.",
  features: [
    {
      title: "KI-Strategieberatung",
      description: "Identifikation der höchsten ROI-Potenziale für Ihr Unternehmen. Analyse Ihrer Prozesse, Priorisierung von Use Cases und Erstellung einer klaren Roadmap.",
    },
    {
      title: "Prozessautomatisierung",
      description: "Automatisierung repetitiver Aufgaben durch KI-gestützte Workflows. Kundenanfragen, Dokumentenverarbeitung, Content-Generierung—in Sekunden erledigt.",
    },
    {
      title: "Tool-Auswahl & Integration",
      description: "Durchblick im Tool-Dschungel. Ich wähle, konfiguriere und integriere die passenden KI-Tools in Ihre bestehenden Systeme—ohne Disruption.",
    },
    {
      title: "Team-Training & Enablement",
      description: "Machen Sie Ihr Team KI-kompetent, nicht KI-abhängig. Praxisnahes Training, das Ihre Mitarbeiter befähigt, KI selbstständig zu nutzen.",
    },
  ],
};

const benefitsData = {
  headline: "Was KI-Integration konkret bringt",
  benefits: [
    {
      icon: "lucide:zap",
      title: "40% Zeitersparnis",
      description: "Durchschnittliche Produktivitätssteigerung durch KI-Automatisierung repetitiver Aufgaben und Workflows.",
    },
    {
      icon: "lucide:trending-up",
      title: "3x schnellere Content-Erstellung",
      description: "Content-Erstellung, Reporting und Analyse in einem Bruchteil der bisherigen Zeit.",
    },
    {
      icon: "lucide:brain",
      title: "Bessere Entscheidungen",
      description: "KI-gestützte Analysen und Insights für datenbasierte Entscheidungen in Echtzeit.",
    },
    {
      icon: "lucide:users",
      title: "Skalierbarer Kundenservice",
      description: "Mehr Kundenanfragen bearbeiten ohne zusätzliches Personal—KI übernimmt Routinefragen.",
    },
    {
      icon: "lucide:shield",
      title: "Wettbewerbsvorteil",
      description: "Schneller arbeiten, intelligenter skalieren und der Konkurrenz einen Schritt voraus sein.",
    },
    {
      icon: "lucide:graduation-cap",
      title: "KI-kompetentes Team",
      description: "Ihre Mitarbeiter werden KI-native und nutzen KI-Tools souverän und selbstständig.",
    },
  ],
};

const processData = {
  headline: "Von der KI-Verwirrung zur Klarheit",
  description: "Ein strukturierter Ansatz, der Potenziale identifiziert, schnell Wert nachweist und Erfolgreiches skaliert.",
  steps: [
    {
      number: "1",
      title: "Analyse & Potenzial-Mapping",
      description: "Wir analysieren Ihre Geschäftsprozesse, identifizieren Automatisierungspotenziale und priorisieren Use Cases nach ROI. Sie erhalten eine klare KI-Roadmap.",
    },
    {
      number: "2",
      title: "Strategie & Tool-Auswahl",
      description: "Ich empfehle die passenden KI-Tools und Vorgehensweisen für Ihre spezifischen Anforderungen. Keine Einheitslösungen—alles maßgeschneidert.",
    },
    {
      number: "3",
      title: "Pilot-Implementierung",
      description: "Wir starten mit einem 30-Tage-Piloten, um schnell Wert zu beweisen. Tools konfigurieren, Integrationen aufsetzen und ersten Workflow automatisieren.",
    },
    {
      number: "4",
      title: "Skalierung & Enablement",
      description: "Erfolgreiche Piloten über das ganze Unternehmen ausrollen. Team schulen, Prozesse dokumentieren und kontinuierliche Optimierung etablieren.",
    },
  ],
};

const ctaData = {
  headline: "Bereit für die KI-Transformation?",
  description: "Lassen Sie uns Ihre KI-Potenziale in einem kostenlosen 30-minütigen Assessment besprechen. Ich identifiziere Ihre Top-3-KI-Use-Cases und zeige Ihnen den konkreten Einstieg.",
  buttonText: "Kostenloses KI-Assessment",
};

const allServices = [
  {
    icon: "lucide:code",
    title: t.services.webDevelopment.title,
    description: t.services.webDevelopment.description,
    href: "/services/web-development",
  },
  {
    icon: "lucide:brain",
    title: t.services.aiEnablement.title,
    description: t.services.aiEnablement.description,
    href: "/services/ai-enablement",
  },
  {
    icon: "lucide:cloud",
    title: t.services.cloudDevops.title,
    description: t.services.cloudDevops.description,
    href: "/services/cloud-devops",
  },
  {
    icon: "lucide:shield",
    title: t.services.security.title,
    description: t.services.security.description,
    href: "/services/security",
  },
];
---

<ServiceLayout
  title={serviceData.title}
  description={serviceData.description}
  serviceName={serviceData.name}
  locale={locale}
>
  <ServiceHero
    title={serviceData.name}
    tagline={serviceData.tagline}
    description={serviceData.heroDescription}
    icon={serviceData.icon}
  />

  <ProblemSection
    headline={problemData.headline}
    description={problemData.description}
    painPoints={problemData.painPoints}
  />

  <SolutionSection
    headline={solutionData.headline}
    description={solutionData.description}
    features={solutionData.features}
  />

  <BenefitsGrid
    headline={benefitsData.headline}
    benefits={benefitsData.benefits}
  />

  <ProcessSection
    headline={processData.headline}
    description={processData.description}
    steps={processData.steps}
  />

  <CTASection
    headline={ctaData.headline}
    description={ctaData.description}
    buttonText={ctaData.buttonText}
  />

  <RelatedServices
    currentService={serviceData.name}
    services={allServices}
  />
</ServiceLayout>
