const processData = {
  headline: "From AI confusion to clarity",
  description: "A structured approach that identifies opportunities, proves value quickly, and scales what works.",
  steps: [
    {
      number: "1",
      title: "Discovery & Opportunity Mapping",
      description: "We analyze your business processes, identify automation potential, and prioritize use cases by ROI. You get a clear AI roadmap.",
    },
    {
      number: "2",
