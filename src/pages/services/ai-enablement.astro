const benefitsData = {
  headline: "What AI enablement delivers",
  benefits: [
    {
      icon: "lucide:zap",
      title: "40% Time Savings",
      description: "Average productivity gain from AI automation of routine tasks and workflows.",
    },
    {
      icon: "lucide:trending-up",
      title: "3x Faster Content",
      description: "Content creation, reporting, and analysis completed in a fraction of the time.",
    },
    {
      icon: "lucide:brain",
      title: "Better Decisions",
      description: "AI-powered analytics and insights that help you make data-driven choices faster.",
