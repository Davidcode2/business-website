      description: "We start with a 30-day pilot to prove value quickly. Configure tools, set up integrations, and automate your first high-impact workflow.",
    },
    {
      number: "4",
      title: "Scale & Enable",
      description: "Expand successful pilots across your organization. Train your team, document processes, and establish ongoing optimization.",
    },
  ],
};

const ctaData = {
  headline: "Ready to lead the AI revolution?",
  description: "Let's discuss your AI opportunities in a free 30-minute assessment. I'll identify your top 3 AI use cases and show you exactly how to get started.",
  buttonText: "Get Your Free AI Assessment",
};

const allServices = [
  {
    icon: "lucide:code",
    title: "Web Development & E-Commerce",
    description: "Websites and shops that sell with clean code and exceptional UX.",
    href: "/services/web-development",
  },
  {
    icon: "lucide:brain",
    title: "AI Enablement",
    description: "Be at the forefront of the productivity enabled by AI.",
    href: "/services/ai-enablement",
  },
  {
    icon: "lucide:cloud",
    title: "Cloud & DevOps",
    description: "Kubernetes deployment, CI/CD pipelines, and scalable infrastructure.",
    href: "/services/cloud-devops",
  },
  {
    icon: "lucide:shield",
    title: "Security Consulting",
    description: "Protect your digital assets with security audits and best practices.",
    href: "/services/security",
  },
