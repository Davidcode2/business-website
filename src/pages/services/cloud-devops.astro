---
import ServiceLayout from '../../layouts/ServiceLayout.astro';
import ServiceHero from '../../components/service/ServiceHero.astro';
import ProblemSection from '../../components/service/ProblemSection.astro';
import SolutionSection from '../../components/service/SolutionSection.astro';
import BenefitsGrid from '../../components/service/BenefitsGrid.astro';
import ProcessSection from '../../components/service/ProcessSection.astro';
import CTASection from '../../components/service/CTASection.astro';
import RelatedServices from '../../components/service/RelatedServices.astro';

const serviceData = {
  name: "Cloud & DevOps",
  title: "Cloud & DevOps | Jakob Lingel",
  description: "Kubernetes deployment, CI/CD pipelines, and scalable infrastructure. Your app stays online, always performs, and grows with your business.",
  tagline: "Built for Scale",
  heroDescription: "Stop worrying about servers, deployments, and downtime. I set up modern cloud infrastructure that automatically scales, self-heals, and deploys your code with zero downtime.",
  icon: "lucide:cloud",
};

const problemData = {
  headline: "Tired of deployment nightmares?",
  description: "Manual deployments, server crashes, and scaling headaches drain your team's energy. Traditional hosting can't handle traffic spikes, and every release feels like a gamble.",
  painPoints: [
    "Manual deployments that take hours and often fail at the worst possible moment",
    "Servers crashing during traffic spikes, losing customers and revenue",
    "No easy rollback when something breaks in production",
    "Security patches and updates that never get applied because they're too risky",
  ],
};

const solutionData = {
  headline: "Infrastructure that just works",
  description: "I build cloud-native infrastructure using Kubernetes, automated CI/CD, and industry best practices. Your application deploys automatically, scales on demand, and stays secure without you lifting a finger.",
  features: [
    {
      title: "Kubernetes Orchestration",
      description: "Container orchestration that automatically scales your app, handles failures, and optimizes resource usage.",
    },
    {
      title: "Zero-Downtime Deploys",
      description: "Blue-green deployments with automatic rollback. New code goes live seamlessly with instant rollback if issues arise.",
    },
    {
      title: "Auto-Scaling",
      description: "Your app scales from one to hundreds of instances automatically based on demand. Pay only for what you use.",
    },
    {
      title: "Security Hardened",
      description: "Network policies, secrets management, vulnerability scanning, and security updates applied automatically.",
    },
  ],
};

const benefitsData = {
  headline: "Why modern infrastructure matters",
  benefits: [
    {
      icon: "lucide:zap",
      title: "Deploy Faster",
      description: "Push code and it's live in minutes. Automated testing and deployment pipelines do the work.",
    },
    {
      icon: "lucide:activity",
      title: "99.9% Uptime",
      description: "Self-healing infrastructure that restarts failed containers and routes around problems.",
    },
    {
      icon: "lucide:trending-up",
      title: "Auto-Scale",
      description: "Handle traffic spikes without breaking a sweat. Scale up instantly, scale down to save costs.",
    },
    {
      icon: "lucide:shield",
      title: "Secure by Design",
      description: "Network isolation, encrypted secrets, and automatic security patches keep you protected.",
    },
    {
      icon: "lucide:git-branch",
      title: "GitOps Workflow",
      description: "Your Git repo is the source of truth. Changes are tracked, auditable, and reversible.",
    },
    {
      icon: "lucide:bar-chart",
      title: "Full Observability",
      description: "Monitoring, logging, and alerting out of the box. Know what's happening before users do.",
    },
  ],
};

const processData = {
  headline: "From code to cloud",
  description: "A methodical approach that gets your infrastructure production-ready with best practices built-in.",
  steps: [
    {
      number: "1",
      title: "Assessment & Design",
      description: "I analyze your current setup, understand your requirements, and design a cloud architecture that meets your needs and budget.",
    },
    {
      number: "2",
      title: "Infrastructure Setup",
      description: "I provision Kubernetes clusters, set up CI/CD pipelines, configure networking, and establish security policies.",
    },
    {
      number: "3",
      title: "Migration & Testing",
      description: "We migrate your application to the new infrastructure, run comprehensive tests, and validate everything works perfectly.",
    },
    {
      number: "4",
      title: "Monitoring & Handoff",
      description: "I set up monitoring dashboards, document the infrastructure, and train your team on day-to-day operations.",
    },
  ],
};

const ctaData = {
  headline: "Ready for infrastructure that scales?",
  description: "Let's discuss your current setup and design a cloud infrastructure that grows with your business. From greenfield projects to migrations, I've got you covered.",
  buttonText: "Start Your Migration",
};

const allServices = [
  {
    icon: "lucide:code",
    title: "Custom Web Development",
    description: "Websites tailored to your business needs with clean code and exceptional UX.",
    href: "/services/web-development",
  },
  {
    icon: "lucide:shopping-cart",
    title: "E-Commerce Solutions",
    description: "Webshops that convert visitors into customers with seamless checkout experiences.",
    href: "/services/ecommerce",
  },
  {
    icon: "lucide:cloud",
    title: "Cloud & DevOps",
    description: "Kubernetes deployment, CI/CD pipelines, and scalable infrastructure.",
    href: "/services/cloud-devops",
  },
  {
    icon: "lucide:shield",
    title: "Security Consulting",
    description: "Protect your digital assets with security audits and best practices.",
    href: "/services/security",
  },
];
---

<ServiceLayout
  title={serviceData.title}
  description={serviceData.description}
  serviceName={serviceData.name}
>
  <ServiceHero
    title={serviceData.name}
    tagline={serviceData.tagline}
    description={serviceData.heroDescription}
    icon={serviceData.icon}
  />

  <ProblemSection
    headline={problemData.headline}
    description={problemData.description}
    painPoints={problemData.painPoints}
  />

  <SolutionSection
    headline={solutionData.headline}
    description={solutionData.description}
    features={solutionData.features}
  />

  <BenefitsGrid
    headline={benefitsData.headline}
    benefits={benefitsData.benefits}
  />

  <ProcessSection
    headline={processData.headline}
    description={processData.description}
    steps={processData.steps}
  />

  <CTASection
    headline={ctaData.headline}
    description={ctaData.description}
    buttonText={ctaData.buttonText}
  />

  <RelatedServices
    currentService={serviceData.name}
    services={allServices}
  />
</ServiceLayout>
