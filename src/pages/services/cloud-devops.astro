---
import ServiceLayout from '../../layouts/ServiceLayout.astro';
import ServiceHero from '../../components/service/ServiceHero.astro';
import ProblemSection from '../../components/service/ProblemSection.astro';
import SolutionSection from '../../components/service/SolutionSection.astro';
import BenefitsGrid from '../../components/service/BenefitsGrid.astro';
import ProcessSection from '../../components/service/ProcessSection.astro';
import CTASection from '../../components/service/CTASection.astro';
import RelatedServices from '../../components/service/RelatedServices.astro';
import { getTranslations } from '../../i18n/translations';

const locale = 'de';
const t = getTranslations(locale);

const serviceData = {
  name: t.services.cloudDevops.title,
  title: t.cloudDevops.meta.title,
  description: t.cloudDevops.meta.description,
  tagline: t.cloudDevops.tagline,
  heroDescription: t.cloudDevops.heroDescription,
  icon: "lucide:cloud",
};

const problemData = {
  headline: "Genug von Deployment-Albträumen?",
  description: "Manuelle Deployments, Server-Abstürze und Skalierungsprobleme zehren an der Energie Ihres Teams. Traditionelles Hosting kann Traffic-Spitzen nicht bewältigen, und jedes Release fühlt sich wie ein Glücksspiel an.",
  painPoints: [
    "Manuelle Deployments, die Stunden dauern und oft im schlimmsten Moment fehlschlagen",
    "Server-Abstürze während Traffic-Spitzen, die Kunden und Umsatz kosten",
    "Kein einfaches Rollback, wenn etwas in Produktion kaputt geht",
    "Sicherheitspatches und Updates, die nie eingespielt werden, weil sie zu riskant erscheinen",
  ],
};

const solutionData = {
  headline: "Infrastruktur, die einfach funktioniert",
  description: "Ich baue Cloud-native Infrastruktur mit Kubernetes, automatisierten CI/CD-Pipelines und branchenerprobten Best Practices. Ihre Anwendung deployt automatisch, skaliert bei Bedarf und bleibt sicher—ohne dass Sie einen Finger rühren müssen.",
  features: [
    {
      title: "Kubernetes-Orchestrierung",
      description: "Container-Orchestrierung, die Ihre App automatisch skaliert, Fehler behebt und Ressourcennutzung optimiert.",
    },
    {
      title: "Zero-Downtime Deployments",
      description: "Blue-Green-Deployments mit automatischem Rollback. Neuer Code geht nahtlos live mit sofortigem Rollback bei Problemen.",
    },
    {
      title: "Auto-Scaling",
      description: "Ihre App skaliert automatisch von einer zu hunderten Instanzen basierend auf der Nachfrage. Bezahlen Sie nur das, was Sie nutzen.",
    },
    {
      title: "Sicherheitshärtung",
      description: "Netzwerk-Richtlinien, Secrets-Management, Vulnerability-Scanning und automatische Sicherheitsupdates.",
    },
  ],
};

const benefitsData = {
  headline: "Warum moderne Infrastruktur entscheidend ist",
  benefits: [
    {
      icon: "lucide:zap",
      title: "Schneller deployen",
      description: "Code pushen und in Minuten live. Automatisierte Tests und Deployment-Pipelines erledigen die Arbeit.",
    },
    {
      icon: "lucide:activity",
      title: "99,9% Verfügbarkeit",
      description: "Selbstheilende Infrastruktur, die fehlgeschlagene Container neu startet und Probleme umgeht.",
    },
    {
      icon: "lucide:trending-up",
      title: "Auto-Scaling",
      description: "Bewältigen Sie Traffic-Spitzen problemlos. Sofort hochskalieren, herunterskalieren um Kosten zu sparen.",
    },
    {
      icon: "lucide:shield",
      title: "Sicher von Haus aus",
      description: "Netzwerk-Isolation, verschlüsselte Secrets und automatische Sicherheitspatches halten Sie geschützt.",
    },
    {
      icon: "lucide:git-branch",
      title: "GitOps Workflow",
      description: "Ihr Git-Repository ist die Single Source of Truth. Änderungen sind nachvollziehbar, auditierbar und reversibel.",
    },
    {
      icon: "lucide:bar-chart",
      title: "Volle Observability",
      description: "Monitoring, Logging und Alerting out of the box. Wissen Sie vor Ihren Nutzern, was passiert.",
    },
  ],
};

const processData = {
  headline: "Vom Code zur Cloud",
  description: "Ein methodischer Ansatz, der Ihre Infrastruktur produktionsreif macht—mit eingebauten Best Practices.",
  steps: [
    {
      number: "1",
      title: "Bewertung & Design",
      description: "Ich analysiere Ihr aktuelles Setup, verstehe Ihre Anforderungen und designe eine Cloud-Architektur, die Ihren Bedürfnissen und Budget entspricht.",
    },
    {
      number: "2",
      title: "Infrastruktur-Setup",
      description: "Ich provisioniere Kubernetes-Cluster, richte CI/CD-Pipelines ein, konfiguriere Netzwerke und etabliere Sicherheitsrichtlinien.",
    },
    {
      number: "3",
      title: "Migration & Testing",
      description: "Wir migrieren Ihre Anwendung auf die neue Infrastruktur, führen umfassende Tests durch und validieren, dass alles perfekt funktioniert.",
    },
    {
      number: "4",
      title: "Monitoring & Übergabe",
      description: "Ich richte Monitoring-Dashboards ein, dokumentiere die Infrastruktur und schule Ihr Team für den täglichen Betrieb.",
    },
  ],
};

const ctaData = {
  headline: "Bereit für skalierbare Infrastruktur?",
  description: "Lassen Sie uns Ihr aktuelles Setup besprechen und eine Cloud-Infrastruktur designen, die mit Ihrem Geschäft wächst. Von Greenfield-Projekten bis Migrationen—ich begleite Sie.",
  buttonText: "Migration starten",
};

const allServices = [
  {
    icon: "lucide:code",
    title: t.services.webDevelopment.title,
    description: t.services.webDevelopment.description,
    href: "/services/web-development",
  },
  {
    icon: "lucide:brain",
    title: t.services.aiEnablement.title,
    description: t.services.aiEnablement.description,
    href: "/services/ai-enablement",
  },
  {
    icon: "lucide:cloud",
    title: t.services.cloudDevops.title,
    description: t.services.cloudDevops.description,
    href: "/services/cloud-devops",
  },
  {
    icon: "lucide:shield",
    title: t.services.security.title,
    description: t.services.security.description,
    href: "/services/security",
  },
];
---

<ServiceLayout
  title={serviceData.title}
  description={serviceData.description}
  serviceName={serviceData.name}
  locale={locale}
>
  <ServiceHero
    title={serviceData.name}
    tagline={serviceData.tagline}
    description={serviceData.heroDescription}
    icon={serviceData.icon}
  />

  <ProblemSection
    headline={problemData.headline}
    description={problemData.description}
    painPoints={problemData.painPoints}
  />

  <SolutionSection
    headline={solutionData.headline}
    description={solutionData.description}
    features={solutionData.features}
  />

  <BenefitsGrid
    headline={benefitsData.headline}
    benefits={benefitsData.benefits}
  />

  <ProcessSection
    headline={processData.headline}
    description={processData.description}
    steps={processData.steps}
  />

  <CTASection
    headline={ctaData.headline}
    description={ctaData.description}
    buttonText={ctaData.buttonText}
  />

  <RelatedServices
    currentService={serviceData.name}
    services={allServices}
  />
</ServiceLayout>
