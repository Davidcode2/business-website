---
import { Icon } from 'astro-icon/components';
import Scene3D from './Scene3D.jsx';
import { getTranslations, type Locale } from '../i18n/translations';

interface Props {
  locale?: Locale;
}

const { locale = 'de' } = Astro.props;
const t = getTranslations(locale);
---

<section class="relative min-h-screen flex items-center justify-center overflow-hidden pt-16">
  <!-- 3D Background -->
  <div class="absolute inset-0 -z-10">
    <Scene3D client:load />
  </div>
  
  <!-- Content -->
  <div class="relative z-10 max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <div class="animate-fade-in-up">
      <!-- Tagline -->
      <p class="text-(--color-accent) font-medium mb-4 tracking-wide uppercase text-sm">
        {t.hero.tagline}
      </p>
      
      <!-- Main headline -->
      <h1 class="text-5xl sm:text-6xl lg:text-7xl font-bold text-(--color-text-primary) mb-6 leading-tight">
        {t.hero.headline1}
        <span class="gradient-text">{t.hero.headline2}</span>
        <br />
        {t.hero.headline3}
      </h1>
      
      <!-- Subheadline -->
      <p class="text-xl text-(--color-text-secondary) mb-10 max-w-2xl mx-auto">
        {t.hero.subheadline}
      </p>
      
      <!-- CTA Buttons -->
      <div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
        <a 
          href="#contact" 
          class="group inline-flex items-center gap-2 px-8 py-4 bg-(--color-accent) text-(--color-text-inverse) rounded-full font-medium hover:bg-(--color-accent-emphasis) transition-all hover:scale-105"
        >
          {t.hero.ctaPrimary}
          <Icon name="lucide:arrow-right" class="w-5 h-5 group-hover:translate-x-1 transition-transform" />
        </a>
        <a 
          href="#services" 
          class="inline-flex items-center gap-2 px-8 py-4 border border-(--color-border) text-(--color-text-primary) rounded-full font-medium hover:bg-(--color-surface-raised) transition-all"
        >
          {t.hero.ctaSecondary}
        </a>
      </div>
    </div>
  </div>
</section>
