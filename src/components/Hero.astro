---
import { Icon } from 'astro-icon/components';
import GradientBlob from './GradientBlob.jsx';
---

<section class="relative min-h-screen flex items-center justify-center overflow-hidden pt-16">
  <!-- Background gradient blobs -->
  <div class="absolute inset-0 overflow-hidden">
    <div class="absolute top-1/4 -left-1/4 w-[600px] h-[600px] bg-(--gradient-blob-1) rounded-full mix-blend-multiply filter blur-[128px] opacity-30 animate-blob"></div>
    <div class="absolute top-1/3 -right-1/4 w-[600px] h-[600px] bg-(--gradient-blob-2) rounded-full mix-blend-multiply filter blur-[128px] opacity-30 animate-blob-delayed"></div>
    <div class="absolute -bottom-1/4 left-1/3 w-[600px] h-[600px] bg-(--gradient-blob-3) rounded-full mix-blend-multiply filter blur-[128px] opacity-30 animate-blob-slow"></div>
  </div>
  
  <!-- 3D Gradient Blob (React component) -->
  <div class="absolute inset-0 opacity-40">
    <GradientBlob client:load />
  </div>
  
  <!-- Content -->
  <div class="relative z-10 max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <div class="animate-fade-in-up">
      <!-- Tagline -->
      <p class="text-(--color-accent) font-medium mb-4 tracking-wide uppercase text-sm">
        Digital Solutions Provider
      </p>
      
      <!-- Main headline -->
      <h1 class="text-5xl sm:text-6xl lg:text-7xl font-bold text-(--color-text-primary) mb-6 leading-tight">
        From idea to
        <span class="gradient-text">deployment</span>
        <br />
        in record time
      </h1>
      
      <!-- Subheadline -->
      <p class="text-xl text-(--color-text-secondary) mb-10 max-w-2xl mx-auto">
        You have a vision. I have the tools to make it real. Custom websites, 
        webshops, and cloud infrastructure—delivered fast.
      </p>
      
      <!-- CTA Buttons -->
      <div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
        <a 
          href="#contact" 
          class="group inline-flex items-center gap-2 px-8 py-4 bg-(--color-accent) text-(--color-text-inverse) rounded-full font-medium hover:bg-(--color-accent-emphasis) transition-all hover:scale-105"
        >
          Let's talk
          <Icon name="lucide:arrow-right" class="w-5 h-5 group-hover:translate-x-1 transition-transform" />
        </a>
        <a 
          href="#services" 
          class="inline-flex items-center gap-2 px-8 py-4 border border-(--color-border) text-(--color-text-primary) rounded-full font-medium hover:bg-(--color-surface-raised) transition-all"
        >
          Explore services
        </a>
      </div>
    </div>
    
    <!-- Scroll indicator -->
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce">
      <div class="w-6 h-10 border-2 border-(--color-border) rounded-full flex justify-center pt-2">
        <div class="w-1.5 h-1.5 bg-(--color-accent) rounded-full animate-pulse"></div>
      </div>
    </div>
  </div>
</section>
