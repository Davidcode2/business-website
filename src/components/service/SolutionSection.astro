---
interface Props {
  headline: string;
  description: string;
  features: Array<{
    title: string;
    description: string;
  }>;
}

const { headline, description, features } = Astro.props;
---

<section class="py-24 sm:py-32 relative bg-(--color-surface-subtle)">
  <!-- Subtle gradient decoration -->
  <div class="absolute inset-0 bg-gradient-to-b from-transparent via-(--color-accent-subtle)/10 to-transparent"></div>
  
  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid lg:grid-cols-2 gap-16 items-center">
      <!-- Features grid -->
      <div class="space-y-6">
        {features.map((feature) => (
          <div class="p-6 rounded-xl bg-(--color-surface-raised) border border-(--color-border) hover:border-(--color-accent-weak) transition-all">
            <h3 class="text-lg font-semibold text-(--color-text-primary) mb-2">
              {feature.title}
            </h3>
            <p class="text-(--color-text-secondary)">
              {feature.description}
            </p>
          </div>
        ))}
      </div>
      
      <!-- Content -->
      <div>
        <p class="text-(--color-accent) font-medium mb-4 tracking-wide uppercase text-sm">
          The Solution
        </p>
        <h2 class="text-3xl sm:text-4xl font-bold text-(--color-text-primary) mb-6 leading-tight">
          <span class="gradient-text">{headline}</span>
        </h2>
        <p class="text-lg text-(--color-text-secondary) leading-relaxed">
          {description}
        </p>
      </div>
    </div>
  </div>
</section>
