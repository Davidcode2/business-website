---
import { Icon } from 'astro-icon/components';

interface Props {
  headline: string;
  description?: string;
  steps: Array<{
    number: string;
    title: string;
    description: string;
  }>;
}

const { headline, description, steps } = Astro.props;
---

<section id="process" class="py-24 sm:py-32 relative bg-(--color-surface-subtle)">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section header -->
    <div class="text-center mb-16">
      <p class="text-(--color-accent) font-medium mb-4 tracking-wide uppercase text-sm">
        How It Works
      </p>
      <h2 class="text-3xl sm:text-4xl font-bold text-(--color-text-primary) mb-6">
        <span class="gradient-text">{headline}</span>
      </h2>
      {description && (
        <p class="text-lg text-(--color-text-secondary) max-w-2xl mx-auto">
          {description}
        </p>
      )}
    </div>
    
    <!-- Process steps -->
    <div class="relative">
      <!-- Connecting line -->
      <div class="absolute left-8 top-8 bottom-8 w-px bg-(--color-border) hidden md:block"></div>
      
      <div class="space-y-8">
        {steps.map((step, index) => (
          <div class="relative flex gap-8 items-start">
            <!-- Step number -->
            <div class="relative z-10 flex-shrink-0 w-16 h-16 rounded-full bg-(--color-accent) text-(--color-text-inverse) flex items-center justify-center text-2xl font-bold">
              {step.number}
            </div>
            
            <!-- Content -->
            <div class="flex-1 pt-2">
              <h3 class="text-xl font-semibold text-(--color-text-primary) mb-2">
                {step.title}
              </h3>
              <p class="text-(--color-text-secondary) leading-relaxed">
                {step.description}
              </p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
