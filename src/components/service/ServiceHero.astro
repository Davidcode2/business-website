---
import { Icon } from 'astro-icon/components';

interface Props {
  title: string;
  tagline: string;
  description: string;
  icon: string;
}

const { title, tagline, description, icon } = Astro.props;
---

<section class="relative min-h-[70vh] flex items-center justify-center overflow-hidden py-24 sm:py-32">
  <!-- Gradient blob decoration - positioned as hero background -->
  <div class="absolute -z-10 top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[150%] h-[150%] bg-gradient-to-r from-(--gradient-blob-1) via-(--gradient-blob-2) to-(--gradient-blob-3) rounded-full filter blur-[120px] opacity-15 animate-blob"></div>
  <div class="absolute -z-10 top-1/3 right-1/4 w-[80%] h-[80%] bg-gradient-to-l from-(--gradient-blob-3) via-(--gradient-blob-1) to-(--gradient-blob-2) rounded-full filter blur-[100px] opacity-10 animate-blob-delayed"></div>
  
  <div class="relative z-10 max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <!-- Icon -->
    <div class="inline-flex items-center justify-center w-20 h-20 rounded-2xl bg-(--color-accent-subtle) border border-(--color-border) mb-8">
      <Icon name={icon} class="w-10 h-10 text-(--color-accent)" />
    </div>
    
    <!-- Tagline -->
    <p class="text-(--color-accent) font-medium mb-4 tracking-wide uppercase text-sm">
      {tagline}
    </p>
    
    <!-- Title -->
    <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold text-(--color-text-primary) mb-6 leading-tight">
      <span class="gradient-text">{title}</span>
    </h1>
    
    <!-- Description -->
    <p class="text-xl text-(--color-text-secondary) mb-10 max-w-3xl mx-auto leading-relaxed">
      {description}
    </p>
    
    <!-- CTA -->
    <div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
      <a 
        href="#contact" 
        class="group inline-flex items-center gap-2 px-8 py-4 bg-(--color-accent) text-(--color-text-inverse) rounded-full font-medium hover:bg-(--color-accent-emphasis) transition-all hover:scale-105"
      >
        Get Started
        <Icon name="lucide:arrow-right" class="w-5 h-5 group-hover:translate-x-1 transition-transform" />
      </a>
      <a 
        href="#process" 
        class="inline-flex items-center gap-2 px-8 py-4 border border-(--color-border) text-(--color-text-primary) rounded-full font-medium hover:bg-(--color-surface-raised) transition-all"
      >
        How It Works
      </a>
    </div>
  </div>
</section>
