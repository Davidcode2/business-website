---
import { Icon } from 'astro-icon/components';

interface Props {
  headline: string;
  description: string;
  painPoints: string[];
}

const { headline, description, painPoints } = Astro.props;
---

<section class="py-24 sm:py-32 relative">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid lg:grid-cols-2 gap-16 items-center">
      <!-- Content -->
      <div>
        <p class="text-(--color-accent) font-medium mb-4 tracking-wide uppercase text-sm">
          The Challenge
        </p>
        <h2 class="text-3xl sm:text-4xl font-bold text-(--color-text-primary) mb-6 leading-tight">
          {headline}
        </h2>
        <p class="text-lg text-(--color-text-secondary) mb-8 leading-relaxed">
          {description}
        </p>
      </div>
      
      <!-- Pain points cards -->
      <div class="space-y-4">
        {painPoints.map((point, index) => (
          <div class="flex items-start gap-4 p-6 rounded-xl bg-(--color-surface-raised) border border-(--color-border)">
            <div class="w-8 h-8 rounded-lg bg-(--color-accent-subtle) flex items-center justify-center flex-shrink-0">
              <Icon name="lucide:x" class="w-5 h-5 text-(--color-accent)" />
            </div>
            <p class="text-(--color-text-secondary)">{point}</p>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
