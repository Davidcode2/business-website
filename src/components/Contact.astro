---
import { Icon } from 'astro-icon/components';
import { getTranslations, type Locale } from '../i18n/translations';

interface Props {
  locale?: Locale;
}

const { locale = 'de' } = Astro.props;
const t = getTranslations(locale);
---

<section id="contact" class="py-24 sm:py-32 relative">
  <!-- Background gradient -->
  <div class="absolute inset-0 bg-gradient-to-b from-transparent via-(--color-accent-subtle)/10 to-transparent"></div>
  
  <div class="relative max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <!-- Section header -->
    <p class="text-(--color-accent) font-medium mb-4 tracking-wide uppercase text-sm">
      {t.contact.sectionTagline}
    </p>
    <h2 class="text-4xl sm:text-5xl font-bold text-(--color-text-primary) mb-6">
      {t.contact.sectionTitle1}
      <span class="gradient-text">{t.contact.sectionTitle2}</span>
    </h2>
    <p class="text-lg text-(--color-text-secondary) mb-12 max-w-2xl mx-auto">
      {t.contact.description}
    </p>
    
    <!-- Email button with protection -->
    <div class="flex flex-col items-center gap-6">
      <button 
        id="email-button"
        class="group inline-flex items-center gap-3 px-8 py-4 bg-(--color-accent) text-(--color-text-inverse) rounded-full font-medium hover:bg-(--color-accent-emphasis) transition-all hover:scale-105"
      >
        <Icon name="lucide:mail" class="w-5 h-5" />
        <span id="email-text">{t.contact.buttonText}</span>
      </button>
      
      <p class="text-sm text-(--color-text-muted)">
        {t.contact.emailHint}
      </p>
    </div>
    
    <!-- Technology Stack Marquee -->
    <div class="mt-20">
      <div class="relative overflow-hidden">
        <!-- Gradient masks for smooth fade -->
        <div class="absolute left-0 top-0 bottom-0 w-32 bg-gradient-to-r from-(--color-background) to-transparent z-10"></div>
        <div class="absolute right-0 top-0 bottom-0 w-32 bg-gradient-to-l from-(--color-background) to-transparent z-10"></div>
        
        <!-- Scrolling marquee container -->
        <div class="marquee-container">
          <div class="marquee-content">
            <!-- First set of technologies -->
            <div class="tech-item">
              <Icon name="simple-icons:astro" class="w-10 h-10" />
              <span>Astro</span>
            </div>
            <div class="tech-item">
              <Icon name="simple-icons:react" class="w-10 h-10" />
              <span>React</span>
            </div>
            <div class="tech-item">
              <Icon name="simple-icons:typescript" class="w-10 h-10" />
              <span>TypeScript</span>
            </div>
            <div class="tech-item">
              <Icon name="simple-icons:angular" class="w-10 h-10" />
              <span>Angular</span>
            </div>
            <div class="tech-item">
              <Icon name="simple-icons:python" class="w-10 h-10" />
              <span>Python</span>
            </div>
            <div class="tech-item">
              <Icon name="simple-icons:rust" class="w-10 h-10" />
              <span>Rust</span>
            </div>
            <div class="tech-item">
              <Icon name="simple-icons:kubernetes" class="w-10 h-10" />
              <span>Kubernetes</span>
            </div>
            <div class="tech-item">
              <Icon name="simple-icons:terraform" class="w-10 h-10" />
              <span>Terraform</span>
            </div>
            <div class="tech-item">
              <Icon name="simple-icons:amazonaws" class="w-10 h-10" />
              <span>AWS</span>
            </div>
            <div class="tech-item">
              <Icon name="simple-icons:ansible" class="w-10 h-10" />
              <span>Ansible</span>
            </div>
            <div class="tech-item">
              <Icon name="simple-icons:github" class="w-10 h-10" />
              <span>GitHub</span>
            </div>
            <div class="tech-item">
              <Icon name="simple-icons:digitalocean" class="w-10 h-10" />
              <span>DigitalOcean</span>
            </div>
            <div class="tech-item">
              <Icon name="simple-icons:hetzner" class="w-10 h-10" />
              <span>Hetzner</span>
            </div>
            <div class="tech-item">
              <Icon name="simple-icons:strapi" class="w-10 h-10" />
              <span>Strapi</span>
            </div>
            
            <!-- Duplicate for seamless loop -->
            <div class="tech-item">
              <Icon name="simple-icons:astro" class="w-10 h-10" />
              <span>Astro</span>
            </div>
            <div class="tech-item">
              <Icon name="simple-icons:react" class="w-10 h-10" />
              <span>React</span>
            </div>
            <div class="tech-item">
              <Icon name="simple-icons:typescript" class="w-10 h-10" />
              <span>TypeScript</span>
            </div>
            <div class="tech-item">
              <Icon name="simple-icons:angular" class="w-10 h-10" />
              <span>Angular</span>
            </div>
            <div class="tech-item">
              <Icon name="simple-icons:python" class="w-10 h-10" />
              <span>Python</span>
            </div>
            <div class="tech-item">
              <Icon name="simple-icons:rust" class="w-10 h-10" />
              <span>Rust</span>
            </div>
            <div class="tech-item">
              <Icon name="simple-icons:kubernetes" class="w-10 h-10" />
              <span>Kubernetes</span>
            </div>
            <div class="tech-item">
              <Icon name="simple-icons:terraform" class="w-10 h-10" />
              <span>Terraform</span>
            </div>
            <div class="tech-item">
              <Icon name="simple-icons:amazonaws" class="w-10 h-10" />
              <span>AWS</span>
            </div>
            <div class="tech-item">
              <Icon name="simple-icons:ansible" class="w-10 h-10" />
              <span>Ansible</span>
            </div>
            <div class="tech-item">
              <Icon name="simple-icons:github" class="w-10 h-10" />
              <span>GitHub</span>
            </div>
            <div class="tech-item">
              <Icon name="simple-icons:digitalocean" class="w-10 h-10" />
              <span>DigitalOcean</span>
            </div>
            <div class="tech-item">
              <Icon name="simple-icons:hetzner" class="w-10 h-10" />
              <span>Hetzner</span>
            </div>
            <div class="tech-item">
              <Icon name="simple-icons:strapi" class="w-10 h-10" />
              <span>Strapi</span>
            </div>
          </div>
        </div>
      </div>
    </div>
    
    <style>
      .marquee-container {
        width: 100%;
        overflow: hidden;
        mask-image: linear-gradient(to right, transparent, black 10%, black 90%, transparent);
        -webkit-mask-image: linear-gradient(to right, transparent, black 10%, black 90%, transparent);
      }
      
      .marquee-content {
        display: flex;
        gap: 4rem;
        animation: scroll 60s linear infinite;
        width: max-content;
      }
      
      .tech-item {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.75rem;
        color: var(--color-text-secondary);
        font-size: 0.875rem;
        font-weight: 500;
        white-space: nowrap;
        transition: color 0.3s ease;
      }
      
      .tech-item:hover {
        color: var(--color-text-primary);
      }
      
      @keyframes scroll {
        0% {
          transform: translateX(0);
        }
        100% {
          transform: translateX(-50%);
        }
      }
      
      /* Pause animation on hover */
      .marquee-container:hover .marquee-content {
        animation-play-state: paused;
      }
    </style>
  </div>
</section>

<script>
  // Email protection - only reveal on click
  const emailButton = document.getElementById('email-button');
  const emailText = document.getElementById('email-text');
  
  // Email parts (obfuscated)
  const parts = ['jakob.lingel', 'hotmail.de'];
  const email = parts[0] + '@' + parts[1];
  
  emailButton?.addEventListener('click', () => {
    if (emailText) {
      emailText.textContent = email;
    }
    // Open mailto link
    window.location.href = `mailto:${email}`;
  });
</script>
