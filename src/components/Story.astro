---
import { getTranslations, type Locale } from '../i18n/translations';

interface Props {
  locale?: Locale;
}

const { locale = 'de' } = Astro.props;
const t = getTranslations(locale);

const valueProps = [
  t.story.valueProps.noMeetings,
  t.story.valueProps.noBloatedTeams,
  t.story.valueProps.justResults,
];

const stats = [
  { value: '5+', label: t.story.stats.experience },
  { value: '20+', label: t.story.stats.projects },
  { value: '100%', label: t.story.stats.satisfaction },
  { value: '24/7', label: t.story.stats.support },
];
---

<section id="about" class="py-24 sm:py-32 relative overflow-hidden">
  <!-- Background decoration -->
  <div class="absolute top-0 right-0 w-1/2 h-full bg-gradient-to-l from-(--color-accent-subtle)/20 to-transparent"></div>
  
  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid lg:grid-cols-2 gap-16 items-center">
      <!-- Left content -->
      <div>
        <p class="text-(--color-accent) font-medium mb-4 tracking-wide uppercase text-sm">
          {t.story.sectionTagline}
        </p>
        <h2 class="text-4xl sm:text-5xl font-bold text-(--color-text-primary) mb-6 leading-tight">
          {t.story.sectionTitle1}
          <span class="gradient-text">{t.story.sectionTitle2}</span>
        </h2>
        <p class="text-lg text-(--color-text-secondary) mb-8 leading-relaxed">
          {t.story.description}
        </p>
        
        <!-- Value props -->
        <div class="space-y-6">
          {valueProps.map((prop) => (
            <div class="flex items-start gap-4">
              <div class="w-2 h-2 rounded-full bg-(--color-accent) mt-2 flex-shrink-0"></div>
              <div>
                <h3 class="font-semibold text-(--color-text-primary) mb-1">
                  {prop.title}
                </h3>
                <p class="text-(--color-text-muted)">
                  {prop.description}
                </p>
              </div>
            </div>
          ))}
        </div>
      </div>
      
      <!-- Right content - Stats/visual -->
      <div class="relative">
        <!-- Stats cards -->
        <div class="grid grid-cols-2 gap-6">
          {stats.map((stat) => (
            <div class="p-6 rounded-2xl bg-(--color-surface-raised) border border-(--color-border)">
              <div class="text-4xl font-bold text-(--color-accent) mb-2">{stat.value}</div>
              <div class="text-(--color-text-secondary)">{stat.label}</div>
            </div>
          ))}
        </div>
        
        <!-- Decorative element -->
        <div class="absolute -z-10 top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[120%] h-[120%] bg-gradient-to-r from-(--gradient-blob-1) via-(--gradient-blob-2) to-(--gradient-blob-3) rounded-full filter blur-[100px] opacity-20"></div>
      </div>
    </div>
  </div>
</section>
