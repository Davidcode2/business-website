---
import { Icon } from 'astro-icon/components';
import { getTranslations, type Locale } from '../i18n/translations';

interface Props {
  locale?: Locale;
}

const { locale = 'de' } = Astro.props;
const t = getTranslations(locale);
const isGerman = locale === 'de';

const services = [
  {
    icon: "lucide:brain",
    title: t.services.aiEnablement.title,
    description: t.services.aiEnablement.description,
    href: isGerman ? "/services/ai-enablement" : "/en/services/ai-enablement"
  },
  {
    icon: "lucide:code",
    title: t.services.webDevelopment.title,
    description: t.services.webDevelopment.description,
    href: isGerman ? "/services/web-development" : "/en/services/web-development"
  },
  {
    icon: "lucide:cloud",
    title: t.services.cloudDevops.title,
    description: t.services.cloudDevops.description,
    href: isGerman ? "/services/cloud-devops" : "/en/services/cloud-devops"
  },
  {
    icon: "lucide:shield",
    title: t.services.security.title,
    description: t.services.security.description,
    href: isGerman ? "/services/security" : "/en/services/security"
  }
];
---

<section id="services" class="py-24 sm:py-32 relative">
  <!-- Subtle background gradient -->
  <div class="absolute inset-0 bg-gradient-to-b from-transparent via-(--color-surface-subtle)/30 to-transparent"></div>
  
  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section header -->
    <div class="text-center mb-16">
      <p class="text-(--color-accent) font-medium mb-4 tracking-wide uppercase text-sm">
        {t.services.sectionTagline}
      </p>
      <h2 class="text-4xl sm:text-5xl font-bold text-(--color-text-primary) mb-6">
        {t.services.sectionTitle1}
        <span class="gradient-text">{t.services.sectionTitle2}</span>
      </h2>
      <p class="text-lg text-(--color-text-secondary) max-w-2xl mx-auto">
        {t.services.sectionDescription}
      </p>
    </div>
    
    <!-- Services grid -->
    <div class="grid md:grid-cols-2 gap-8">
      {services.map((service, index) => (
        <a 
          href={service.href}
          class="group p-8 rounded-2xl bg-(--color-surface-subtle) border border-(--color-border) hover:border-(--color-accent-weak) transition-all duration-300 hover:-translate-y-1 cursor-pointer"
          style={`animation-delay: ${index * 100}ms`}
        >
          <!-- Icon -->
          <div class="w-14 h-14 rounded-xl bg-(--color-accent-subtle) flex items-center justify-center mb-6 group-hover:bg-(--color-accent-muted) transition-colors">
            <Icon name={service.icon} class="w-7 h-7 text-(--color-accent)" />
          </div>
          
          <!-- Content -->
          <h3 class="text-xl font-semibold text-(--color-text-primary) mb-3 group-hover:text-(--color-accent) transition-colors">
            {service.title}
          </h3>
          <p class="text-(--color-text-secondary) leading-relaxed">
            {service.description}
          </p>
          
          <!-- Learn more link -->
          <div class="mt-6 flex items-center text-(--color-accent) font-medium opacity-0 group-hover:opacity-100 transition-opacity">
            <span>{t.services.webDevelopment.learnMore}</span>
            <Icon name="lucide:arrow-right" class="w-4 h-4 ml-2 transform group-hover:translate-x-1 transition-transform" />
          </div>
        </a>
      ))}
    </div>
  </div>
</section>
