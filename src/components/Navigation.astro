---
import { Icon } from 'astro-icon/components';
import { getRelativeLocaleUrl } from 'astro:i18n';

interface Props {
  currentLocale?: string;
  currentPath?: string;
  isServicePage?: boolean;
}

const { currentLocale = 'de', currentPath = '', isServicePage = false } = Astro.props;

const isGerman = currentLocale === 'de';
const alternateLocale = isGerman ? 'en' : 'de';

// Build the alternate URL path
let alternatePath = currentPath;
if (alternateLocale === 'en') {
  // Going to English - add /en prefix
  alternatePath = '/en' + currentPath;
} else {
  // Going to German - remove /en prefix
  alternatePath = currentPath.replace(/^\/en/, '') || '/';
}

const homeUrl = isGerman ? "/" : "/en/";
const servicesUrl = isServicePage ? `${homeUrl}#services` : "#services";
const contactUrl = isServicePage ? `${homeUrl}#contact` : "#contact";
const aboutUrl = isServicePage ? `${homeUrl}#about` : "#about";
---

<nav class="fixed top-0 left-0 right-0 z-50 border-b border-(--color-border) backdrop-blur-xl">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 bg-blur">
    <div class="flex justify-between items-center h-16">
      <!-- Logo -->
      <a href={isGerman ? "/" : "/en/"} class="text-xl font-semibold text-(--color-text-primary) hover:text-(--color-accent) transition-colors">
        Jakob Lingel
      </a>
      
      <!-- Desktop Navigation -->
      <div class="hidden md:flex items-center gap-8">
        <div class="relative group">
          <a href={servicesUrl} class="text-(--color-text-secondary) hover:text-(--color-text-primary) transition-colors flex items-center gap-1">
            Services
            <Icon name="lucide:chevron-down" class="w-4 h-4" />
          </a>
          <!-- Services Dropdown -->
          <div class="absolute top-full left-0 mt-2 w-80 py-2 bg-(--color-surface-raised) border border-(--color-border) rounded-xl opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 shadow-xl">
            <a href={isGerman ? "/services/web-development" : "/en/services/web-development"} class="block px-4 py-3 text-(--color-text-secondary) hover:text-(--color-text-primary) hover:bg-(--color-surface-subtle) transition-colors">
              <div class="font-medium">Web Development & E-Commerce</div>
              <div class="text-sm opacity-70">{isGerman ? 'Websites die verkaufen' : 'Websites that sell'}</div>
            </a>
            <a href={isGerman ? "/services/ai-enablement" : "/en/services/ai-enablement"} class="block px-4 py-3 text-(--color-text-secondary) hover:text-(--color-text-primary) hover:bg-(--color-surface-subtle) transition-colors">
              <div class="font-medium">AI Enablement</div>
              <div class="text-sm opacity-70">{isGerman ? 'An der Spitze der KI' : 'Be at the forefront of AI'}</div>
            </a>
            <a href={isGerman ? "/services/cloud-devops" : "/en/services/cloud-devops"} class="block px-4 py-3 text-(--color-text-secondary) hover:text-(--color-text-primary) hover:bg-(--color-surface-subtle) transition-colors">
              <div class="font-medium">Cloud & DevOps</div>
              <div class="text-sm opacity-70">{isGerman ? 'Infrastruktur die skaliert' : 'Infrastructure that scales'}</div>
            </a>
            <a href={isGerman ? "/services/security" : "/en/services/security"} class="block px-4 py-3 text-(--color-text-secondary) hover:text-(--color-text-primary) hover:bg-(--color-surface-subtle) transition-colors">
              <div class="font-medium">Security Consulting</div>
              <div class="text-sm opacity-70">{isGerman ? 'Schützen Sie Ihre Assets' : 'Protect your assets'}</div>
            </a>
          </div>
        </div>
        <a href={aboutUrl} class="text-(--color-text-secondary) hover:text-(--color-text-primary) transition-colors">
          {isGerman ? 'Über mich' : 'About'}
        </a>
        <a href={contactUrl} class="text-(--color-text-secondary) hover:text-(--color-text-primary) transition-colors">
          {isGerman ? 'Kontakt' : 'Contact'}
        </a>
        
        <!-- Language Toggle -->
        <a 
          href={alternatePath}
          class="flex items-center gap-1.5 px-3 py-1.5 rounded-full border border-(--color-border) text-(--color-text-secondary) hover:text-(--color-text-primary) hover:bg-(--color-surface-raised) transition-all text-sm font-medium"
          aria-label={isGerman ? 'Switch to English' : 'Zu Deutsch wechseln'}
          title={isGerman ? 'Switch to English' : 'Zu Deutsch wechseln'}
        >
          <span class={isGerman ? 'text-(--color-accent)' : ''}>DE</span>
          <span class="text-(--color-text-muted)">/</span>
          <span class={!isGerman ? 'text-(--color-accent)' : ''}>EN</span>
        </a>
        
        <!-- Theme Toggle -->
        <button 
          id="theme-toggle"
          class="p-2 rounded-lg text-(--color-text-secondary) hover:text-(--color-text-primary) hover:bg-(--color-surface-raised) transition-all"
          aria-label="Toggle theme"
        >
          <Icon name="lucide:sun" class="w-5 h-5 hidden dark:block" />
          <Icon name="lucide:moon" class="w-5 h-5 block dark:hidden" />
        </button>
      </div>
      
      <!-- Mobile menu button -->
      <button 
        id="mobile-menu-button"
        class="md:hidden p-2 rounded-lg text-(--color-text-secondary) hover:text-(--color-text-primary) hover:bg-(--color-surface-raised) transition-all"
        aria-label="Open menu"
      >
        <Icon name="lucide:menu" class="w-6 h-6" id="menu-icon" />
      </button>
    </div>
  </div>
  
  <!-- Mobile Navigation -->
  <div id="mobile-menu" class="hidden md:hidden border-t border-(--color-border) bg-(--color-surface-base)">
    <div class="px-4 py-4 space-y-1">
      <div class="py-2">
        <div class="text-(--color-text-primary) font-medium mb-2">Services</div>
        <div class="pl-4 space-y-2 border-l-2 border-(--color-border)">
          <a href={isGerman ? "/services/web-development" : "/en/services/web-development"} class="block text-(--color-text-secondary) hover:text-(--color-text-primary) transition-colors py-1 text-sm">
            Web Development & E-Commerce
          </a>
          <a href={isGerman ? "/services/ai-enablement" : "/en/services/ai-enablement"} class="block text-(--color-text-secondary) hover:text-(--color-text-primary) transition-colors py-1 text-sm">
            AI Enablement
          </a>
          <a href={isGerman ? "/services/cloud-devops" : "/en/services/cloud-devops"} class="block text-(--color-text-secondary) hover:text-(--color-text-primary) transition-colors py-1 text-sm">
            Cloud & DevOps
          </a>
          <a href={isGerman ? "/services/security" : "/en/services/security"} class="block text-(--color-text-secondary) hover:text-(--color-text-primary) transition-colors py-1 text-sm">
            Security Consulting
          </a>
        </div>
      </div>
      <a href={aboutUrl} class="block text-(--color-text-secondary) hover:text-(--color-text-primary) transition-colors py-2">
        {isGerman ? 'Über mich' : 'About'}
      </a>
      <a href={contactUrl} class="block text-(--color-text-secondary) hover:text-(--color-text-primary) transition-colors py-2">
        {isGerman ? 'Kontakt' : 'Contact'}
      </a>
      
      <!-- Mobile Language Toggle -->
      <div class="py-4 border-t border-(--color-border) mt-4">
        <a 
          href={alternatePath}
          class="flex items-center justify-between px-4 py-3 rounded-xl bg-(--color-surface-raised) border border-(--color-border) text-(--color-text-secondary) hover:text-(--color-text-primary) hover:bg-(--color-surface-overlay) transition-all"
        >
          <span class="text-sm font-medium">{isGerman ? 'Switch to English' : 'Zu Deutsch wechseln'}</span>
          <span class="flex items-center gap-2 px-3 py-1.5 rounded-full bg-(--color-surface-base) border border-(--color-border) text-sm font-semibold">
            <span class={isGerman ? 'text-(--color-accent)' : 'text-(--color-text-muted)'}>DE</span>
            <span class="text-(--color-border)">|</span>
            <span class={!isGerman ? 'text-(--color-accent)' : 'text-(--color-text-muted)'}>EN</span>
          </span>
        </a>
      </div>
    </div>
  </div>
</nav>

<script>
  // Theme toggle functionality
  const themeToggle = document.getElementById('theme-toggle');
  const html = document.documentElement;
  
  themeToggle?.addEventListener('click', () => {
    const currentTheme = html.getAttribute('data-theme');
    const newTheme = currentTheme === 'dark' ? 'light' : 'dark';
    html.setAttribute('data-theme', newTheme);
    localStorage.setItem('theme', newTheme);
  });
  
  // Mobile menu toggle
  const mobileMenuButton = document.getElementById('mobile-menu-button');
  const mobileMenu = document.getElementById('mobile-menu');
  const menuIcon = document.getElementById('menu-icon');
  let isMenuOpen = false;
  
  mobileMenuButton?.addEventListener('click', () => {
    isMenuOpen = !isMenuOpen;
    mobileMenu?.classList.toggle('hidden');
    
    // Update icon
    if (menuIcon) {
      menuIcon.setAttribute('name', isMenuOpen ? 'lucide:x' : 'lucide:menu');
    }
  });
  
  // Close mobile menu when clicking a link
  mobileMenu?.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', () => {
      isMenuOpen = false;
      mobileMenu.classList.add('hidden');
      if (menuIcon) {
        menuIcon.setAttribute('name', 'lucide:menu');
      }
    });
  });
</script>
